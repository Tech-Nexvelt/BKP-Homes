NODE_ENV=development
PORT=5000
DATABASE_URL=postgresql://postgres:password@localhost:5432/luxora_db
JWT_SECRET=your_jwt_secret_minimum_64_characters_long_random_string_change_this
JWT_REFRESH_SECRET=your_refresh_secret_minimum_64_characters_long_change_this_now
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
FRONTEND_URL=http://localhost:3000
BCRYPT_ROUNDS=12
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASS=your_app_password
FROM_EMAIL=noreply@luxora.in
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
LOG_LEVEL=info
